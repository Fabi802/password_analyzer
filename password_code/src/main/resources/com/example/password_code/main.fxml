<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.Tab?>


<TabPane fx:id="root"
         xmlns:fx="http://javafx.com/fxml"
         xmlns="http://javafx.com/javafx"
         fx:controller="com.example.password_code.Controller">


    <!-- Tab 1: check password -->
    <Tab text="Analyze" closable="false">
        <VBox spacing="12"
              alignment="CENTER"
              style="-fx-padding: 20;"
              styleClass="root-pane">

            <Label text="Password Analyzer"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;" />

            <HBox spacing="5" alignment="CENTER">

                <PasswordField fx:id="passwordField"
                               promptText="enter password"
                               prefWidth="210"/>

                <TextField fx:id="textField"
                           promptText="enter password"
                           prefWidth="210"
                           visible="false"
                           managed="false"/>

                <Button fx:id="toggleButton"
                        text="👁"
                        onAction="#togglePassword"
                        prefWidth="40"/>
            </HBox>

            <Button text="check"
                    onAction="#checkPassword"
                    prefWidth="120"/>

            <ProgressBar fx:id="strengthBar"
                         prefWidth="250"
                         progress="0"/>

            <Label fx:id="resultLabel"/>

        </VBox>
    </Tab>

    <!-- Tab 2: generate password -->
    <Tab text="Generate" closable="false">
        <VBox spacing="15"
              alignment="CENTER"
              style="-fx-padding: 20;"
              styleClass="root-pane">

            <Label text="Password Generator"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;" />

            <TextField fx:id="generatedPasswordField"
                       editable="false"
                       prefWidth="250"
                       promptText="generated password"/>

            <Button text="generate password"
                    onAction="#generatePassword"
                    prefWidth="180"/>

        </VBox>
    </Tab>

    <!-- Tab 3: Settings -->
    <Tab text="Settings" closable="false">
        <VBox alignment="CENTER" spacing="10"
              styleClass="root-pane">

            <Button text="🌙 Dark Mode"
                    onAction="#toggleDarkMode"/>

        </VBox>
    </Tab>

</TabPane>